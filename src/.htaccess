# public/.htaccess
RewriteEngine On

# Ensure the base is correct (usually just /)
RewriteBase /

# 1. Stop processing if the request is an actual file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Redirect everything else to index.php
# The [QSA] flag ensures your query strings (?id=1) are preserved
# The [L] flag tells Apache this is the last rule to process
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]